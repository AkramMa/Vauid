{
  "manifest_version": 3,
  "name": "VauID Password Manager",
  "version": "1.0.0",
  "description": "Browser extension for VauID \u2014 autofill, search, and TOTP from your local vault.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "clipboardWrite",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "*://127.0.0.1/*",
    "*://localhost/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src ws://127.0.0.1:* wss://127.0.0.1:* http://127.0.0.1:* https://127.0.0.1:*; script-src 'self'; img-src 'self' https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "VauID",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "popup/*.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}